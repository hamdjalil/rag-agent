# Copy this file to .env and fill in your keys
# Never commit .env to version control

# Required: Groq (generation + grading) — free at console.groq.com
GROQ_API_KEY=gsk_...

# Required: Tavily (web search fallback) — free at app.tavily.com
TAVILY_API_KEY=tvly-...

# Optional: LangSmith tracing
# Free at https://smith.langchain.com — set these and traces appear automatically
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=rag-agent
